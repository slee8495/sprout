# Postgres (Vercel Postgres / Neon)
DATABASE_URL=

# Auth.js
AUTH_SECRET=

# Families sign up at /signup (creates a family + invite code) and invite
# members at /join. No env vars needed for auth anymore — it's all per-family
# data in the database now.

# Vercel Blob (photo storage)
BLOB_READ_WRITE_TOKEN=

# Vercel AI Gateway — only needed for local dev; not needed once deployed on Vercel (uses OIDC)
AI_GATEWAY_API_KEY=
