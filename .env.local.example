# Postgres (Vercel Postgres / Neon)
DATABASE_URL=

# Auth.js
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated allowlist of the two family emails allowed to sign in
