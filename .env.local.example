# Postgres (Vercel Postgres / Neon)
DATABASE_URL=

# Auth.js
AUTH_SECRET=

# Shared passphrase both parents use to sign in (pick something memorable, not generated)
APP_PASSPHRASE=

# Comma-separated display names shown on the login dropdown / used as the journal author
PARENT_NAMES="Dad,Mom"

# Used once, the first time either parent signs in, to create the single family row
FAMILY_NAME="The Lee Family"

# Vercel Blob (photo storage)
BLOB_READ_WRITE_TOKEN=

# Vercel AI Gateway — only needed for local dev; not needed once deployed on Vercel (uses OIDC)
AI_GATEWAY_API_KEY=
